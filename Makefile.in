prefix = @prefix@
program_transform_name = @program_transform_name@
psdir = @psdir@
runstatedir = @runstatedir@
sbindir = @sbindir@
sharedstatedir = @sharedstatedir@
srcdir = @srcdir@
sysconfdir = @sysconfdir@
target_alias = @target_alias@
top_build_prefix = @top_build_prefix@
top_builddir = @top_builddir@
top_srcdir = @top_srcdir@
ACLOCAL_AMFLAGS = -I m4 --install
AUTOMAKE_OPTIONS = foreign subdir-objects -Wno-portability
@CODE_COVERAGE_ENABLED_TRUE@GITIGNOREFILES := $(GITIGNOREFILES) $(CODE_COVERAGE_OUTPUT_FILE) $(CODE_COVERAGE_OUTPUT_DIRECTORY)
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_cap = $(code_coverage_v_lcov_cap_$(V))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_cap_ = $(code_coverage_v_lcov_cap_$(AM_DEFAULT_VERBOSITY))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_cap_0 = @echo "  LCOV   --capture" $(CODE_COVERAGE_OUTPUT_FILE);
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_ign = $(code_coverage_v_lcov_ign_$(V))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_ign_ = $(code_coverage_v_lcov_ign_$(AM_DEFAULT_VERBOSITY))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_lcov_ign_0 = @echo "  LCOV   --remove" "$(CODE_COVERAGE_OUTPUT_FILE).tmp" $(CODE_COVERAGE_IGNORE_PATTERN);
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_genhtml = $(code_coverage_v_genhtml_$(V))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_genhtml_ = $(code_coverage_v_genhtml_$(AM_DEFAULT_VERBOSITY))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_v_genhtml_0 = @echo "  GEN   " "$(CODE_COVERAGE_OUTPUT_DIRECTORY)";
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_quiet = $(code_coverage_quiet_$(V))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_quiet_ = $(code_coverage_quiet_$(AM_DEFAULT_VERBOSITY))
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_quiet_0 = --quiet

# sanitizes the test-name: replaces with underscores: dashes and dots
@CODE_COVERAGE_ENABLED_TRUE@code_coverage_sanitize = $(subst -,_,$(subst .,_,$(1)))
@CODE_COVERAGE_ENABLED_TRUE@AM_DISTCHECK_CONFIGURE_FLAGS := $(AM_DISTCHECK_CONFIGURE_FLAGS) --disable-code-coverage
SUBDIRS = lib

#--------------------------------------------------------------------------
EXTRA_DIST = $(srcdir)/silent-rules.mk COPYING INSTALL README AUTHORS \
	$(srcdir)/write-siphash-implementations.awk \
	$(srcdir)/write-halfsiphash-implementations.awk \
	m4/gnulib-cache.m4 $(ARRAY_PRF_SATS) $(ARRAY_PRF_DATS) \
	$(SIPHASH_SATS) $(SIPHASH_DATS) $(HALFSIPHASH_SATS) \
	$(HALFSIPHASH_DATS) $(KEY_SATS) $(KEY_DATS) $(KEY_CATS) \
	$(ATOMIC_CATS) $(ATOMIC_SATS) $(ATOMIC_DATS) $(SIPHASH_CATS) \
	$(SIPHASH_HATS) $(HALFSIPHASH_HATS) $(SIPHASH_C_DATS) \
	$(HALFSIPHASH_C_DATS) $(KEY_C_DATS) tests/vectors.sats \
	tests/vectors-2-4.dats tests/vectors-4-8.dats \
	$(DISTRIBUTED_ATS2_TESTS:%=%.dats) \
	$(M4_GENERATED_ATS2_TESTS:%=%.dats.m4) \
	$(DISTRIBUTED_C_TESTS:%=%.c) $(M4_GENERATED_C_TESTS:%=%.c.m4) \
	reference-implementation/halfsiphash.c \
	reference-implementation/halfsiphash.h \
	reference-implementation/LICENSE \
	reference-implementation/makefile \
	reference-implementation/README.md \
	reference-implementation/siphash.c \
	reference-implementation/siphash.h \
	reference-implementation/test.c \
	reference-implementation/testmain.c \
	reference-implementation/vectors.h
MOSTLYCLEANFILES = 
CLEANFILES = $(ARRAY_PRF_SATS_C) $(ARRAY_PRF_DATS_C) $(SIPHASH_SATS_C) \
	$(SIPHASH_DATS_C) $(HALFSIPHASH_SATS_C) $(HALFSIPHASH_DATS_C) \
	$(KEY_SATS_C) $(KEY_DATS_C) $(ATOMIC_SATS_C) $(ATOMIC_DATS_C) \
	$(SIPHASH_C_DATS_C) $(HALFSIPHASH_C_DATS_C) $(KEY_C_DATS_C) \
	tests/vectors_sats.c tests/vectors-2-4_dats.c \
	tests/vectors-4-8_dats.c $(DISTRIBUTED_ATS2_TESTS:%=%_dats.c) \
	$(M4_GENERATED_ATS2_TESTS:%=%.dats) \
	$(M4_GENERATED_ATS2_TESTS:%=%_dats.c) \
	$(M4_GENERATED_C_TESTS:%=%.c)
DISTCLEANFILES = Makefile GNUmakefile lib/Makefile lib/GNUmakefile \
	$(SIPHASH_SATS_EXTRA) $(SIPHASH_DATS_EXTRA) \
	$(HALFSIPHASH_SATS_EXTRA) $(HALFSIPHASH_DATS_EXTRA)
BUILT_SOURCES = 
AM_CPPFLAGS = -I$(builddir) -I$(srcdir) -I$(PATSHOME) \
	-I$(PATSHOME)/ccomp/runtime/ -I$(builddir)/lib -I$(srcdir)/lib
AM_CFLAGS = 
AM_LDFLAGS = 
LDADD = $(CODE_COVERAGE_LIBS)

#--------------------------------------------------------------------------
#
# The ATS2 library.
#

#
# The following probably should not be installed.
#
#nobase_nodist_pkginclude_HEADERS += $(KEY_DATS)
#nobase_nodist_pkginclude_HEADERS += $(ATOMIC_SATS)
#nobase_nodist_pkginclude_HEADERS += $(ATOMIC_DATS)

#--------------------------------------------------------------------------
#
# The C library.
#
lib_LTLIBRARIES = libats2-siphash.la libsiphash.la
nobase_nodist_pkginclude_HEADERS = $(ARRAY_PRF_SATS) $(ARRAY_PRF_DATS) \
	$(SIPHASH_CATS) $(SIPHASH_SATS) $(SIPHASH_DATS) \
	$(SIPHASH_HATS) $(HALFSIPHASH_SATS) $(HALFSIPHASH_DATS) \
	$(HALFSIPHASH_HATS) $(KEY_CATS) $(KEY_SATS) $(SIPHASH_C_DATS) \
	$(HALFSIPHASH_C_DATS) siphash/siphash.h siphash/halfsiphash.h \
	siphash/key.h

#--------------------------------------------------------------------------
nodist_pkgconfig_DATA = ats2-siphash.pc siphash.pc
CODE_COVERAGE_IGNORE_PATTERN = /usr/include/* /usr/include/*/* \
	$(PATSHOME)/ccomp/runtime/* $(PATSHOME)/prelude/CATS/*

#---------------------------------------------------------------------
#
# Some GNU Make aids you might want to use.
#
