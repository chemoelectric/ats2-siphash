prefix=@prefix@
exec_prefix=@exec_prefix@
libdir=@libdir@
includedir=@includedir@
host=@host@
package=@PACKAGE@
version=@VERSION@
pkgincludedir="${includedir}/${package}"

# You can override this with
# --define-variable=PATSHOME="${PATSHOME}"
PATSHOME="@PKGCONFIG_PATSHOME@"

CPPFLAGS=-I${pkgincludedir} -I${PATSHOME} -I${PATSHOME}/ccomp/runtime

# Options for patsopt.
PATSOPTFLAGS=-IATS ${pkgincludedir}

# Options for patscc.
PATSCCFLAGS=-IIATS ${pkgincludedir}

Name: ${package}
Description: SipHash for ATS2
Version: ${version}
Libs: -L${libdir} -lats2-siphash
Cflags: ${CPPFLAGS}
